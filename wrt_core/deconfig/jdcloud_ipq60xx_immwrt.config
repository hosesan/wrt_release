# 京东云亚瑟 AX1800 Pro 专用配置（含 iStore 优化）
CONFIG_TARGET_ipq60xx=y
CONFIG_TARGET_ipq60xx_DEVICE_jdcloud_arthur=y

# 中文界面和基础工具
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-zh-cn=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# 硬盘/U盘挂载支持（NTFS/ext4）
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_luci-app-mountd=y

# Docker 全家桶（带图形管理界面）
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_luci-app-dockerman=y

# Samba 匿名共享（免密码访问硬盘）
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_SAMBA4_GUEST_OK=y

# 网络和无线加速
CONFIG_PACKAGE_kmod-nss-ifb=y
CONFIG_PACKAGE_wifi=y
CONFIG_PACKAGE_luci-app-firewall=y

# iStore 商店（核心配置 + 开机自启）
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_iStore=y
CONFIG_PACKAGE_iStore-core=y
CONFIG_PACKAGE_iStore-luci=y
CONFIG_PACKAGE_iStore-autorun=y
